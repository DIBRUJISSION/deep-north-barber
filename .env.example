# Environment Variables Example
# Copy this to .env.local and fill in actual values
# Never commit .env.local to Git

# Database (if adding backend later)
# DATABASE_URL=

# API Keys (if needed)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_ANALYTICS_KEY=

# Booking System (currently using Timely external link)
# TIMELY_API_KEY=

# Admin/CMS (future enhancement)
# ADMIN_SECRET=

# Notes:
# - NEXT_PUBLIC_ prefix makes variable available to browser
# - Without prefix, only available server-side
# - Never expose sensitive keys to browser
# - Use server actions for sensitive API calls
